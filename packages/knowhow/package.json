{
  "name": "@tyvm/knowhow",
  "version": "0.0.108-dev.c47492f",
  "description": "ai cli with plugins and agents",
  "main": "ts_build/src/index.js",
  "bin": {
    "knowhow": "bin/knowhow.js"
  },
  "scripts": {
    "test": "jest --testTimeout 300000",
    "test:debug": "node --inspect-brk ../../node_modules/jest/bin/jest.js --detectOpenHandles --forceExit --testTimeout 300000",
    "build": "npm run compile",
    "compile": "npm run clean && tsc",
    "clean": "rm -rf ts_build",
    "node:build": "bash scripts/build-for-node.sh",
    "start": "npm run compile && node --no-node-snapshot ts_build/src/server/index.js",
    "dataset:diffs:generate": "ts-node src/dataset/diffs/generate.ts",
    "dataset:diffs:jsonl": "ts-node src/dataset/diffs/jsonl.ts",
    "prepublishOnly": "npm run compile && bash scripts/check-isolated-deps.sh",
    "check:isolated": "bash scripts/check-isolated-deps.sh",
    "lint": "tslint ./src/**/*.ts",
    "lint:deps": "depcheck --config=.depcheckrc",
    "lint:all": "npm run lint && npm run lint:deps",
    "check:model-pricing": "ts-node scripts/check-model-pricing.ts",
    "version:nightly": "bash scripts/publish.sh version:nightly",
    "version:dev": "bash scripts/publish.sh version:dev",
    "publish:nightly": "bash scripts/publish.sh nightly",
    "publish:dev": "bash scripts/publish.sh dev",
    "publish:latest": "bash scripts/publish.sh stable",
    "publish:stable": "bash scripts/publish.sh stable"
  },
  "keywords": [],
  "author": "Micah Riggan",
  "license": "MIT",
  "devDependencies": {
    "@babel/preset-typescript": "^7.23.3",
    "typescript": "^5.0.0",
    "@types/diff": "^5.2.1",
    "@types/express": "^4.17.13",
    "@types/jest": "^29.5.13",
    "@types/mocha": "^10.0.8",
    "@types/node": "^20.6.3",
    "@types/pdf-parse": "^1.1.4",
    "@types/ws": "^8.18.1",
    "jest": "^29.1.1",
    "prettier": "2.6.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.7.0",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^0.14.1",
    "@inquirer/editor": "^4.2.18",
    "@modelcontextprotocol/sdk": "^1.13.3",
    "@simplewebauthn/server": "^13.3.0",
    "@tyvm/knowhow-tunnel": "0.0.5",
    "commander": "^14.0.0",
    "diff": "^5.2.0",
    "express": "^4.19.2",
    "gitignore-to-glob": "^0.3.0",
    "glob": "11.1.0",
    "isolated-vm": "^5.0.4",
    "jiti": "^2.6.1",
    "marked": "^10.0.0",
    "marked-terminal": "^6.2.0",
    "minimatch": "^10.1.2",
    "node-jq": "^6.0.1",
    "openai": "4.89.1",
    "pdf-parse": "^1.1.1",
    "ws": "^8.18.1",
    "zod": "^3.25.0"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tyvm-ai/knowhow.git"
  },
  "types": "./ts_build/src/index.d.ts",
  "bugs": {
    "url": "https://github.com/tyvm-ai/knowhow/issues"
  },
  "homepage": "https://github.com/tyvm-ai/knowhow#readme",
  "optionalDependencies": {
    "esbuild-register": "^3.0.0"
  }
}
